# ── Base de datos (Neon Postgres, vía Vercel Storage) ─────────────────────────
# Local: pegá la connection string de Neon. En Vercel se setea sola al conectar
# la integración de Neon/Postgres.
POSTGRES_URL="postgresql://user:password@host/db?sslmode=require"

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Creá una key en https://console.anthropic.com/ (API Keys) y pegala acá.
ANTHROPIC_API_KEY="sk-ant-..."

# ── Modelos (opcional) ────────────────────────────────────────────────────────
# Default: claude-haiku-4-5 (el más rápido/barato). Subí a claude-sonnet-4-6
# (balanceado) o claude-opus-4-8 (el más capaz) si querés más calidad.
# QUIZ_MODEL="claude-haiku-4-5"
# TUTOR_MODEL="claude-haiku-4-5"
